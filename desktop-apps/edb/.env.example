# eDB Environment Configuration
# Copy this file to .env and customize

# Database
EDB_DB_PATH=edb_data.db

# API Server
EDB_API_HOST=127.0.0.1
EDB_API_PORT=8000

# Security — CHANGE THESE IN PRODUCTION!
EDB_JWT_SECRET=change-me-to-a-strong-random-secret
EDB_ENCRYPTION_KEY=change-me-to-a-strong-encryption-key

# Token expiration
EDB_JWT_ACCESS_EXPIRE_MINUTES=60
EDB_JWT_REFRESH_EXPIRE_DAYS=7

# Rate limiting
EDB_RATE_LIMIT_ENABLED=true
EDB_RATE_LIMIT_REQUESTS=100
EDB_RATE_LIMIT_WINDOW_SECONDS=60

# Logging
EDB_LOG_LEVEL=INFO

# Audit
EDB_AUDIT_ENABLED=true

# Auto-create admin user
EDB_CREATE_ADMIN=true

# ebot AI
EDB_EBOT_ENABLED=true
EDB_EBOT_PROVIDER=rule_based
# For LLM mode: set provider to 'openai' and provide API key
# EDB_EBOT_PROVIDER=openai
# EDB_EBOT_OPENAI_API_KEY=sk-...
# EDB_EBOT_OPENAI_MODEL=gpt-3.5-turbo
